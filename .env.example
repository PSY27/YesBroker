# YesBroker environment variables
# Copy to .env and paste your Gemini API key:
#   cp .env.example .env
#
# Get a key at: https://aistudio.google.com/apikey

GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.1-pro-preview

# Search behavior
# Keep search fast: scrape + rank only, and run the 5-agent investigation
# on-demand when a listing is clicked. With this true, search runs the full
# investigation on up to 10 listings before returning, which makes the SSE
# stream long enough that the browser reconnects and the UI resets.
INVESTIGATE_ON_SEARCH=false
